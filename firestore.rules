rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwn(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/ibadah/{doc} {
      allow read, write: if isOwn(uid);
    }

    match /users/{uid}/muhasabaEntries/{doc} {
      allow read, write: if isOwn(uid);
    }

    match /users/{uid}/habits/{habitId} {
      allow read, write: if isOwn(uid);

      match /logs/{logId} {
        allow read, write: if isOwn(uid);
      }
    }

    match /users/{uid}/tasks/{doc} {
      allow read, write: if isOwn(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
